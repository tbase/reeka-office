{
  "name": "reeka-office-miniprogram",
  "type": "module",
  "version": "1.0.6",
  "private": true,
  "description": "海纳家办小程序",
  "keywords": [],
  "scripts": {
    "dev": "VITE_TENANT_LOCAL_API=http://localhost:3001 wv dev",
    "dev:open": "wv dev -o",
    "build": "wv build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "open": "wv open",
    "stylelint": "stylelint \"src/**/*.{css,scss,vue,wxss}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss,vue,wxss}\" --fix --allow-empty-input",
    "postinstall": "weapp-tw patch && wv prepare"
  },
  "dependencies": {
    "@wevu/api": "^0.2.6",
    "tdesign-miniprogram": "^1.14.0"
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@icebreakers/eslint-config": "^4.0.8",
    "@icebreakers/stylelint-config": "^3.0.5",
    "@iconify-json/mdi": "^1.2.3",
    "@reeka-office/jsonrpc": "workspace:*",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "miniprogram-api-typings": "^5.1.3",
    "postcss": "^8.5.10",
    "sass": "^1.99.0",
    "stylelint": "^17.9.0",
    "tailwindcss": "3.4.19",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7",
    "weapp-tailwindcss": "^4.11.2",
    "weapp-vite": "^6.15.14",
    "wevu": "^6.15.14"
  }
}
