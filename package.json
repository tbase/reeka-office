{
  "name": "reeka-office",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:api-center": "pnpm --filter api-center dev",
    "dev:admin": "pnpm --filter admin dev",
    "db:push:tenant": "drizzle-kit push --config=drizzle/tenant.config.ts",
    "db:push:center": "drizzle-kit push --config=drizzle/center.config.ts",
    "tabicon": "pnpm --filter reeka-office-miniprogram tabicon",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10"
  }
}
